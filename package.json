{
  "name": "open-weather-map-api",
  "version": "1.0.0",
  "description": "Open Weatcher Map Api Integration Service",
  "main": "index.ts",
  "scripts": {
    "predev": "npm run migration:run",
    "dev": "nodemon --watch src --ext ts,json --exec ts-node -r tsconfig-paths/register  --files src/index.ts",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "prestart": "npm run migration:run",
    "start": "node dist/index.js",
    "typeorm": "node --require ts-node/register r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js  migration:generate -d src/db/data-source.ts",
    "migration:run": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/db/data-source.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MhKh78/open-weather-map-api.git"
  },
  "keywords": [
    "weatcher-api",
    "open-source",
    "integration"
  ],
  "author": "MhKh",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MhKh78/open-weather-map-api/issues"
  },
  "homepage": "https://github.com/MhKh78/open-weather-map-api#readme",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.1",
    "redis": "^4.7.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "0.3.25"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
